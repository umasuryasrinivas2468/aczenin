# Google Sheets webhook URL from Google Apps Script deployment
NEXT_PUBLIC_SHEET_WEBHOOK_URL=your_google_apps_script_url_here

# Sanity — copy to .env and fill in your own values.
# Find these at https://www.sanity.io/manage after creating your project.
NEXT_PUBLIC_SANITY_PROJECT_ID=aghe2n16
NEXT_PUBLIC_SANITY_DATASET=aczen

# --- Blog automation (Sheets -> Gemini -> Sanity, fires daily via Vercel Cron) ---
# Sanity write token: create at https://www.sanity.io/manage -> API -> Tokens (Editor or Write).
SANITY_WRITE_TOKEN=
# Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional model overrides
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Apps Script /exec URL from scripts/google-apps-script/Code.gs (server-only)
BLOG_SHEET_WEBHOOK_URL=
# Shared secret — must match SHARED_SECRET script property on the Apps Script side
BLOG_SHEET_SECRET=
# Random string. Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
